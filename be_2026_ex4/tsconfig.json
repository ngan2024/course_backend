{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "target": "ES2022",
        "skipLibCheck": true,
        "allowJs": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}